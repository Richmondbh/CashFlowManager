<Window x:Class="CashFlowManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cash Flow Manager"
        Height="820" Width="1100"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#2196F3"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding"      Value="16"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1"
                                      Opacity="0.12" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderBrush"     Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#FAFAFA"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderBrush"     Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#FAFAFA"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="BorderBrush"     Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#FAFAFA"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR======================================== -->
        <Border Grid.Row="0" Background="#1565C0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💰" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock Text="Cash Flow Manager"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="💾  Save"
                            Style="{StaticResource SuccessButton}"
                            Margin="0,0,6,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="📂  Load"
                            Style="{StaticResource PrimaryButton}"
                            Background="#0288D1"
                            Margin="0,0,6,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Content="📊  Report"
                            Style="{StaticResource PrimaryButton}"
                            Background="#7B1FA2"
                            Click="OpenReportWindow_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT ====================================== -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ─────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="0"
                          Margin="0,0,10,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ADD TRANSACTION CARD -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Add Transaction" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding InputDate}" Margin="0,0,0,8"/>

                            <TextBlock Text="Amount" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding InputAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Category Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding InputCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Category Type" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CategoryTypeOptions}"
                                      SelectedItem="{Binding InputCategoryType}"
                                      Margin="0,0,0,8"/>

                            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding InputDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <Button Content="+  Add Transaction"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddTransactionCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- CASH-FLOW SUMMARY CARD -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Cash-Flow Summary" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Month" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableMonths}"
                                      SelectedItem="{Binding SelectedMonth}"
                                      Margin="0,0,0,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat='MMMM yyyy'}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Revenue"
                                           Foreground="#388E3C" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalRevenue, StringFormat=C}"
                                           Foreground="#388E3C" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Expenses"
                                           Foreground="#D32F2F" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalExpense, StringFormat=C}"
                                           Foreground="#D32F2F" FontWeight="SemiBold"/>
                            </Grid>

                            <Separator Margin="0,4,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CashFlowLabel}"
                                           FontSize="14" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding NetCashFlow, StringFormat=C}"
                                           FontSize="14" FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- BUDGET CARD -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Set Category Budget" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Category Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding BudgetCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="Monthly Budget Amount" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding BudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <Button Content="✔  Set Budget"
                                    Style="{StaticResource SuccessButton}"
                                    Command="{Binding SetBudgetCommand}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
            <!-- END LEFT PANEL -->

            <!-- RIGHT PANEL  -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SEARCH AND FILTER CARD -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search section -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Search" Style="{StaticResource SectionHeader}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding SearchDate}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                    <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SearchCategory, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SearchDescription, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="🔍  Search"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,6,0"
                                        Command="{Binding SearchCommand}"/>
                                <Button Content="✖  Clear"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding ClearSearchCommand}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Filter section -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Filter" Style="{StaticResource SectionHeader}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding FilterTypeOptions}"
                                              SelectedItem="{Binding FilterTypeString}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Month" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding AvailableMonths}"
                                              SelectedItem="{Binding FilterMonth}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat='MMMM yyyy'}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="⚙  Filter"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#FF9800"
                                        Margin="0,0,6,0"
                                        Command="{Binding FilterCommand}"/>
                                <Button Content="✖  Clear"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding ClearFilterCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TRANSACTION LIST CARD -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Transactions"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0"/>
                            <Button Grid.Column="1"
                                    Content="🗑  Delete Selected"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding DeleteTransactionCommand}"/>
                        </Grid>

                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding DisplayedTransactions}"
                                  SelectedItem="{Binding SelectedTransaction}"
                                  BorderThickness="1"
                                  BorderBrush="#E0E0E0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Date"        Width="100"
                                                    DisplayMemberBinding="{Binding Date, StringFormat='dd/MM/yyyy'}"/>
                                    <GridViewColumn Header="Category"    Width="120"
                                                    DisplayMemberBinding="{Binding Category.Name}"/>
                                    <GridViewColumn Header="Type"        Width="90"
                                                    DisplayMemberBinding="{Binding Category.Type}"/>
                                    <GridViewColumn Header="Amount"      Width="100"
                                                    DisplayMemberBinding="{Binding Amount, StringFormat=C}"/>
                                    <GridViewColumn Header="Description" Width="200"
                                                    DisplayMemberBinding="{Binding Description}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding DisplayedTransactions.Count, StringFormat='Showing {0} transaction(s)'}"
                                   FontSize="11" Foreground="#9E9E9E"
                                   Margin="0,6,0,0"/>
                    </Grid>
                </Border>

            </Grid>
            <!-- END RIGHT PANEL -->

        </Grid>
        <!-- END MAIN CONTENT -->

        <!-- STATUS BAR =============== -->
        <Border Grid.Row="2" Background="#EEEEEE" Padding="12,6"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="#616161"/>
        </Border>

    </Grid>
</Window>